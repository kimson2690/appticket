APP_NAME=AppTicket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Base de données MySQL AppTicket
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=appticket
DB_USERNAME=root
DB_PASSWORD=

# Configuration Laravel
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail (optionnel)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@appticket.com"
MAIL_FROM_NAME="${APP_NAME}"
